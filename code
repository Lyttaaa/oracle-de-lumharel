@bot.event
async def on_raw_reaction_add(payload: discord.RawReactionActionEvent):
    # Filtre de guilde si défini
    if GUILD_ID and payload.guild_id != GUILD_ID:
        return
    # ignore le bot lui-même
    if payload.user_id == bot.user.id:
        return

    guild = bot.get_guild(payload.guild_id)
    if not guild:
        return
    member = guild.get_member(payload.user_id)
    if not member or member.bot:
        return

    emoji = str(payload.emoji)
    channel = bot.get_channel(payload.channel_id)
    message_id = payload.message_id

    # Debug
    print(f"📩 Réaction: {emoji} | msg={message_id} | user={member.display_name}")

    # Identifier la divinité par le message
    deity_name, deity = find_deity_by_message(message_id)
    if not deity:
        # Pas un message d'autel
        return

    # Document utilisateur
    user_id = str(member.id)
    user = utilisateurs.find_one({"_id": user_id})
    if not user:
        utilisateurs.insert_one({
            "_id": user_id,
            "pseudo": member.name,
            "lumes": 0,
            "derniere_benediction": "",
            "roles_temporaires": {},   # { role_name: iso_timestamp }
            "offrandes": {},           # { "Orrak": "YYYY-MM-DD", ... }
            "dernier_autel": ""        # nom de la divinité de la dernière bénédiction
        })
        user = utilisateurs.find_one({"_id": user_id}) or {}

    today = today_str()

    # ----- PRIÈRE (bénédiction: 1/jour global) -----
    if emoji == deity["priere_emoji"]:
        last_bless = user.get("derniere_benediction", "")
        if last_bless == today:
            # déjà béni·e aujourd'hui → MP avec rôle + autel
            roles_temp = user.get("roles_temporaires", {}) or {}
            role_name = next(iter(roles_temp.keys()), None)  # ex: "Béni·e par la Terre"
            autel_precis = user.get("dernier_autel") or deity_name

            if role_name:
                msg = f"✨ Tu as déjà reçu une bénédiction aujourd’hui : **{role_name}**."
            else:
                msg = f"✨ Tu as déjà reçu une bénédiction aujourd’hui (Autel de {autel_precis})."

            try:
                await member.send(msg)
            except Forbidden:
                await send_temp(channel, msg, 10)
            return

        role_name = deity["role"]
        role = discord.utils.get(guild.roles, name=role_name)
        if role is None:
            try:
                role = await guild.create_role(name=role_name, reason="Oracle: bénédiction")
            except Forbidden:
                print(f"❌ Impossible de créer le rôle {role_name} (permissions).")
                return

        try:
            await member.add_roles(role, reason="Oracle: bénédiction du jour")
        except Forbidden:
            print(f"❌ Impossible d'ajouter le rôle {role_name} à {member.display_name}.")
            return

        utilisateurs.update_one(
            {"_id": user_id},
            {"$set": {
                "derniere_benediction": today,
                f"roles_temporaires.{role_name}": datetime.utcnow().isoformat(),
                "pseudo": member.name,
                "dernier_autel": deity_name  # <-- on enregistre le nom de l'autel
            }},
            upsert=True
        )
        await send_temp(channel, f"✨ {member.mention} reçoit la bénédiction **{role_name}** (Autel de {deity_name}).", 30)
        return

    # ----- OFFRANDE (Lumes: 1/jour global, tous autels confondus) -----
    if emoji in deity["offrandes"]:
        last_offrande = user.get("derniere_offrande", "")
        if last_offrande == today:
            autel_precis = user.get("dernier_autel_offrande", "un autel")
            await send_temp(
                channel,
                f"⚠️ {member.mention}, tu as déjà fait une offrande aujourd’hui "
                f"à **{autel_precis}**. Une seule offrande est possible par jour.",
                10
            )
            return

        utilisateurs.update_one(
            {"_id": user_id},
            {"$set": {
                "derniere_offrande": today,
                "dernier_autel_offrande": deity_name,
                "pseudo": member.name
            }, "$inc": {
                "lumes": LUMES_PAR_OFFRANDE
            }},
            upsert=True
        )
        await send_temp(
            channel,
            f"🏱 Offrande acceptée par **{deity_name}**. "
            f"{member.mention} gagne **+{LUMES_PAR_OFFRANDE} Lumes**.",
            30
        )
        return

    # Sinon: emoji non géré pour cet autel → on ignore
    print(f"ℹ️ Emoji {emoji} ignoré pour l'autel {deity_name}.")

# ======================
#   TÂCHE: nettoyage rôles (24h)
# ======================
@tasks.loop(hours=1)
async def cleanup_roles():
    try:
        now = datetime.utcnow()
        for guild in bot.guilds:
            for member in guild.members:
                if member.bot:
                    continue
                user_id = str(member.id)
                user = utilisateurs.find_one({"_id": user_id}) or {}
                roles_temp = user.get("roles_temporaires", {}) or {}
                to_unset = []

                for role_name, iso_ts in roles_temp.items():
                    try:
                        assigned = datetime.fromisoformat(iso_ts)
                    except Exception:
                        to_unset.append(role_name)
                        continue
                    if now - assigned >= timedelta(hours=DUREE_BENEDICTION_H):
                        role = discord.utils.get(guild.roles, name=role_name)
                        if role and role in member.roles:
                            try:
                                await member.remove_roles(role, reason="Oracle: bénédiction expirée")
                            except Forbidden:
                                pass
                        to_unset.append(role_name)

                if to_unset:
                    utilisateurs.update_one(
                        {"_id": user_id},
                        {"$unset": {f"roles_temporaires.{r}": "" for r in to_unset}}
                    )
    except Exception as e:
        print("⚠️ cleanup_roles error:", e)

