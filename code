        role_name = next(iter(roles_temp.keys()), "Bénédiction active")
        autel_precis = user.get("dernier_autel", None)

        if autel_precis and role_name != "Bénédiction active":
            await interaction.response.send_message(
                f"✨ {interaction.user.mention}, ta bénédiction du jour est **{role_name}** (Autel de {autel_precis})."
            )
        else:
            await interaction.response.send_message(
                f"✨ {interaction.user.mention}, ta bénédiction du jour est **{role_name}**."
            )
    else:
        await interaction.response.send_message(
            f"🌙 {interaction.user.mention}, tu n’as pas encore reçu de bénédiction aujourd’hui."
        )

